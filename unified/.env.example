# =============================================================================
# DATABASE CONFIGURATION (Neon PostgreSQL)
# =============================================================================
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# =============================================================================
# AFRICA'S TALKING CONFIGURATION
# =============================================================================
AT_USERNAME=sandbox
AT_API_KEY=your_api_key_here
AT_SHORTCODE=code

# =============================================================================
# HUGGING FACE CONFIGURATION (for LLM fallback)
# =============================================================================
# Option 1: Use Hugging Face Inference API (recommended for production)
HF_API_TOKEN=hf_your_token_here
HF_MODEL_ID=google/flan-t5-small
HF_USE_API=true

# Option 2: Use local model (requires transformers + torch)
# HF_USE_API=false

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
DEBUG=true
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8001
LOG_LEVEL=INFO

# NLP Confidence Thresholds
CONFIDENCE_THRESHOLD_HIGH=0.80
CONFIDENCE_THRESHOLD_LOW=0.50

# Session timeout for clarification flow (minutes)
SESSION_TIMEOUT_MINUTES=30
